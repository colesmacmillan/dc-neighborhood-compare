---
const { neighborhoods } = Astro.props;
---

<section class="map-card">
  <div class="map-header">
    <div>
      <p class="map-kicker">Map</p>
      <h2>See where each neighborhood sits in the city</h2>
    </div>
    <p class="map-copy">Selected neighborhoods stay highlighted on the map for quick visual comparison.</p>
  </div>
  <div id="dc-map" class="map-frame" aria-label="Map of Washington, DC neighborhoods"></div>
</section>

<script define:vars={{ neighborhoods }}>
  const state = window.dcCompareState ?? { selected: [] };
  window.dcCompareState = state;

  const leafletAssets = async () => {
    if (!document.querySelector('link[data-leaflet="styles"]')) {
      const link = document.createElement("link");
      link.rel = "stylesheet";
      link.href = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.css";
      link.dataset.leaflet = "styles";
      document.head.append(link);
    }

    if (window.L) return window.L;

    await new Promise((resolve, reject) => {
      const existing = document.querySelector('script[data-leaflet="script"]');
      if (existing) {
        existing.addEventListener("load", () => resolve(), { once: true });
        existing.addEventListener("error", reject, { once: true });
        return;
      }

      const script = document.createElement("script");
      script.src = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js";
      script.dataset.leaflet = "script";
      script.onload = () => resolve();
      script.onerror = reject;
      document.body.append(script);
    });

    return window.L;
  };

  const emitSelection = () => {
    document.dispatchEvent(
      new CustomEvent("dc-compare:selection-change", {
        detail: { selected: [...state.selected] },
      }),
    );
  };

  const updateSelection = (name) => {
    if (state.selected.includes(name)) {
      state.selected = state.selected.filter((value) => value !== name);
    } else {
      state.selected = [...state.selected, name];
    }
    emitSelection();
  };

  const initializeMap = async () => {
    const L = await leafletAssets();
    const map = L.map("dc-map", { zoomControl: true }).setView([38.9072, -77.0369], 12.4);

    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      attribution: "&copy; OpenStreetMap contributors",
    }).addTo(map);

    const markers = new Map();

    neighborhoods.forEach((neighborhood) => {
      const marker = L.circleMarker([neighborhood.lat, neighborhood.lon], {
        radius: 8,
        weight: 2,
        color: "#0f766e",
        fillColor: "#f7efe0",
        fillOpacity: 0.9,
      }).addTo(map);

      marker.bindPopup(
        `<strong>${neighborhood.name}</strong><br />$${neighborhood.rent_1br.toLocaleString()} 1BR`,
      );
      marker.on("click", () => updateSelection(neighborhood.name));
      markers.set(neighborhood.name, marker);
    });

    const renderMarkerState = () => {
      neighborhoods.forEach((neighborhood) => {
        const marker = markers.get(neighborhood.name);
        const selected = state.selected.includes(neighborhood.name);
        marker.setStyle({
          radius: selected ? 12 : 8,
          color: selected ? "#8a4b16" : "#0f766e",
          fillColor: selected ? "#c26a22" : "#f7efe0",
          fillOpacity: selected ? 0.95 : 0.9,
        });
      });
    };

    document.addEventListener("dc-compare:selection-change", (event) => {
      state.selected = event.detail.selected;
      renderMarkerState();
    });

    renderMarkerState();
  };

  initializeMap().catch((error) => {
    console.error("Leaflet failed to load", error);
    const mapRoot = document.getElementById("dc-map");
    if (mapRoot) {
      mapRoot.innerHTML =
        "<p class='map-error'>Map failed to load. Check your internet connection for Leaflet tiles.</p>";
    }
  });
</script>

<style>
  .map-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 28px;
    box-shadow: var(--shadow);
    padding: 22px;
    min-height: 560px;
  }

  .map-header {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 18px;
  }

  .map-kicker {
    margin: 0 0 8px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .map-header h2 {
    margin: 0;
  }

  .map-copy {
    max-width: 34ch;
    margin: 0;
    color: var(--muted);
    line-height: 1.55;
  }

  .map-frame {
    height: 470px;
    width: 100%;
    border-radius: 22px;
    overflow: hidden;
    border: 1px solid rgba(31, 37, 34, 0.08);
  }

  .map-error {
    padding: 24px;
    color: var(--muted);
  }

  @media (max-width: 720px) {
    .map-card {
      min-height: unset;
    }

    .map-header {
      flex-direction: column;
    }

    .map-copy {
      max-width: none;
    }

    .map-frame {
      height: 360px;
    }
  }
</style>
