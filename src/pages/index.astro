---
import dataset from "../../data/neighborhoods.json";
import MapSection from "../components/MapSection.astro";
import InfoPanel from "../components/InfoPanel.astro";
import Comparison from "../components/Comparison.astro";

const neighborhoods = dataset.neighborhoods ?? [];
const osmLastUpdatedLabel = dataset.osm_last_updated_label ?? dataset.last_updated_label ?? "Unknown";
const zillowLastUpdatedLabel =
  dataset.zillow_last_updated_label ?? dataset.last_updated_label ?? "Unavailable";
const zillowMethod =
  dataset.zillow_method ??
  "Neighborhood rent estimates are scaled from broader Zillow proxy geographies and should be treated as directional estimates.";
const updateNote =
  dataset.update_note ??
  "OpenStreetMap metrics and rent estimates are refreshed from external sources when available.";
const failures = Array.isArray(dataset.failures) ? dataset.failures : [];
const radiusDisclosure = neighborhoods
  .map((neighborhood) => `${neighborhood.name}: ${neighborhood.radius_m}m`)
  .join(" | ");
const metricDisclosure =
  "Food & drink: restaurant, fast food, cafe, bar, pub, food court, biergarten. Nightlife: bar, pub, nightclub. Grocery: supermarket, convenience. Green space: park, garden. Transit infrastructure: platforms, stations, stop positions, rail stops, bus stations. Metro stops: unique named subway stations.";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>DC Neighborhood Compare</title>
  </head>
  <body>
    <main class="page-shell">
      <section class="hero">
        <p class="eyebrow">Washington, DC relocation tool</p>
        <h1>Compare DC neighborhoods side-by-side before the move.</h1>
        <p class="intro">
          Explore popular post-grad neighborhoods in DC with static JSON data generated from
          OpenStreetMap and view their lifestyle metrics on a map.
        </p>
      </section>

      <div class="top-grid">
        <MapSection neighborhoods={neighborhoods} />
        <InfoPanel neighborhoods={neighborhoods} />
      </div>

      <Comparison neighborhoods={neighborhoods} />

      <section class="data-status" aria-label="Dataset information">
        <div class="data-status-block">
          <h2>Data transparency</h2>
          <p>{updateNote}</p>
        </div>
        <div class="data-status-block">
          <h3>OpenStreetMap</h3>
          <p><strong>Last updated:</strong> {osmLastUpdatedLabel}</p>
          <p>Food, nightlife, grocery, green space, and transit counts come from OpenStreetMap features gathered around each neighborhood center point.</p>
        </div>
        <div class="data-status-block">
          <h3>Zillow rent estimates</h3>
          <p><strong>Last updated:</strong> {zillowLastUpdatedLabel}</p>
          <p>{zillowMethod}</p>
        </div>
        <div class="data-status-block">
          <h3>Neighborhood radius</h3>
          <p>{radiusDisclosure}</p>
        </div>
        <div class="data-status-block">
          <h3>Metric definitions</h3>
          <p>{metricDisclosure}</p>
        </div>
        <div class="data-status-block">
          <h3>Failures and fallbacks</h3>
          {
            failures.length ? (
              <ul>
                {failures.map((item) => <li>{item}</li>)}
              </ul>
            ) : (
              <p>No source failures were recorded in the most recent refresh.</p>
            )
          }
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --bg: #f4f1e8;
    --surface: rgba(255, 253, 248, 0.9);
    --surface-strong: #fffdf8;
    --text: #1f2522;
    --muted: #5f675f;
    --line: rgba(31, 37, 34, 0.12);
    --accent: #0f766e;
    --accent-soft: rgba(15, 118, 110, 0.12);
    --shadow: 0 22px 48px rgba(44, 52, 44, 0.08);
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
    font-family: Georgia, "Times New Roman", serif;
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.75), transparent 30%),
      linear-gradient(180deg, #f8f5ed 0%, var(--bg) 100%);
    color: var(--text);
  }

  body {
    padding: 32px 20px 64px;
  }

  .page-shell {
    max-width: 1180px;
    margin: 0 auto;
  }

  .hero {
    margin-bottom: 28px;
  }

  .eyebrow {
    margin: 0 0 10px;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }

  h1 {
    margin: 0;
    font-size: clamp(2.6rem, 6vw, 5rem);
    line-height: 0.95;
  }

  .intro {
    max-width: none;
    margin: 18px 0 0;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--muted);
  }

  .top-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    gap: 24px;
    align-items: start;
  }

  .data-status {
    display: grid;
    gap: 10px;
    margin-top: 30px;
    padding-top: 10px;
    border-top: 1px solid rgba(31, 37, 34, 0.08);
    color: rgba(95, 103, 95, 0.82);
    font-size: 0.84rem;
    line-height: 1.4;
  }

  .data-status-block h2,
  .data-status-block h3,
  .data-status strong {
    color: rgba(31, 37, 34, 0.88);
  }

  .data-status-block h2,
  .data-status-block h3,
  .data-status-block p {
    margin: 0;
  }

  .data-status-block {
    display: grid;
    gap: 4px;
  }

  .data-status-block ul {
    margin: 0;
    padding-left: 16px;
  }

  .data-status-block h2 {
    font-size: 0.84rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .data-status-block h3 {
    font-size: 0.82rem;
    font-weight: 600;
  }

  @media (max-width: 900px) {
    body {
      padding: 20px 14px 40px;
    }

    .top-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
